{
  "name": "tuantuan-emotion-outlet",
  "version": "2.0.0",
  "description": "情绪出口 · 团团桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.tuantuan.emotion-outlet",
    "productName": "情绪出口",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "../src/**/*",
      "../config/**/*",
      "../assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": ["src/**/*", "config/**/*", "assets/**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "../assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
